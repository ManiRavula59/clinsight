# Environment Variables — Copy this to `.env` and fill in your values

# ─── OpenRouter API Keys (get from https://openrouter.ai) ────────────────────
# Prescription Engine Pool (Keys 1-3)
PRESCRIPTION_KEY_1=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRESCRIPTION_KEY_2=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRESCRIPTION_KEY_3=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Retrieval Engine Pool (Keys 4-6)
RETRIEVAL_KEY_1=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RETRIEVAL_KEY_2=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RETRIEVAL_KEY_3=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twilio (get from https://console.twilio.com) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Google (Optional — legacy, replaced by OpenRouter) ──────────────────────
GOOGLE_API_KEY=your_google_api_key_here
